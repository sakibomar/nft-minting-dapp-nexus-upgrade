# Express server port
PORT=5000

# Sepolia RPC endpoint used by the server
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<alchemy-key>

# Deployed contract addresses
CONTRACT_ADDRESS=0x026793AE8e6fcEb59d5BFaEa80C56BffbE349738
MARKETPLACE_ADDRESS=0x45F9EC0878f1236E4705C23099CaF6315C61D2dA

# Runtime mode
NODE_ENV=development

# Pinata API credentials
PINATA_API_KEY=<pinata-api-key>
PINATA_SECRET_KEY=<pinata-secret-key>

# Optional dedicated Pinata gateway settings
PINATA_GATEWAY_URL=https://<subdomain>.mypinata.cloud
PINATA_GATEWAY_KEY=<optional-pinata-gateway-key>

# Optional rate limit and history tuning
API_RATE_LIMIT_MAX=2000
ENABLE_API_RATE_LIMIT=false
RPC_NETWORK=sepolia
HISTORY_CONTRACT_SCAN_DEPTH=30
HISTORY_CONTRACT_SCAN_TIMEOUT_MS=10000
HISTORY_FALLBACK_DEPTH=500
